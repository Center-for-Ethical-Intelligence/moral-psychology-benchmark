# Model provider credentials.
# OPENROUTER_API_KEY is the default fallback for all models.
OPENROUTER_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Volcengine Ark (ByteDance) — for Qwen3, DeepSeek-V3.2, etc.
# Create endpoints at: https://cloud.bytedance.net/ark/region:ark+cn-beijing/endpoint
ARK_API_KEY=

# Together AI — backup provider for Qwen-235B, etc.
TOGETHER_API_KEY=

# DeepSeek direct API — cheaper for DeepSeek R1, R1-Distill
DEEPSEEK_API_KEY=

# Google AI Studio — free for Gemma models (rate-limited)
GOOGLE_API_KEY=

# Hugging Face access for gated datasets and hub downloads.
HF_TOKEN=
HUGGING_FACE_HUB_TOKEN=

# Moral-psych benchmark data roots.
# Only set the benchmarks you actually plan to run; missing paths only block those tasks.
UNIMORAL_DATA_DIR=/absolute/path/to/data/unimoral
UNIMORAL_LANGUAGE=all
UNIMORAL_MODE=np
SMID_DATA_DIR=/absolute/path/to/data/smid
VALUEPRISM_RELEVANCE_FILE=/absolute/path/to/data/valueprism/relevance/relevance_train.csv
VALUEPRISM_VALENCE_FILE=/absolute/path/to/data/valueprism/valence/valence_train.csv
CCD_BENCH_DATA_FILE=/absolute/path/to/data/ccd-bench/CCD-Bench.json

# Denevil expects a benchmark-faithful MoralPrompt-style export for `denevil_generation`.
# A FULCRA-style dialogue file can still be used for the explicit proxy task
# `denevil_fulcra_proxy_generation`.
DENEVIL_DATA_FILE=

# ---- Cloud GPU backends (cei run --backend aws|gcp|azure) ----

# AWS — configure via `aws configure` or set these:
# AWS_PROFILE=default
# AWS_REGION=us-east-1

# GCP — configure via `gcloud auth login` and `gcloud config set project <ID>`:
# GCP_PROJECT=my-project-id
# GCP_ZONE=us-central1-a

# Azure — configure via `az login`:
# AZURE_SUBSCRIPTION_ID=

# SSH key for cloud instances (shared across providers):
# CEI_SSH_KEY=~/.ssh/id_ed25519

# Docker registry for `cei build --push`:
# CEI_DOCKER_REGISTRY=ghcr.io/center-for-ethical-intelligence
